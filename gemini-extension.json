{
  "name": "mcp-db-context-enrichment",
  "version": "0.3.0",
  "contextFileName": "./mcp/GEMINI.md",
  "mcpServers": {
    "mcp_db_context_enrichment": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "${extensionPath}/mcp",
        "main.py"
      ]
    },
    "mcp_toolbox": {
      "command": "${extensionPath}/mcp/toolbox",
      "args": [
        "--stdio"
      ]
    }
  }
}
